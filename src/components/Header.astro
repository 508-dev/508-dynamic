---
type Route = {
  name: string;
  route?: string;
  subItems?: { name: string; route: string }[];
};

const routes: Route[] = [
  {
    name: "Home",
    route: "/",
  },
  {
    name: "Our Expertise",
    subItems: [
      {
        name: "Product",
        route: "/expertise/product",
      },
      {
        name: "AI",
        route: "/expertise/ai",
      },
      {
        name: "Data",
        route: "/expertise/data",
      },
      {
        name: "Observability",
        route: "/expertise/observability",
      },
      {
        name: "Infrastructure",
        route: "/expertise/infrastructure",
      },
    ],
  },

  {
    name: "Pricing",
    route: "/pricing",
  },
  {
    name: "Portfolio",
    route: "/portfolio",
  },
  {
    name: "Blog",
    route: "https://blog.508.dev",
  },
  {
    name: "Members",
    route: "/members",
  },
  {
    name: "Join",
    route: "/join",
  },
];

// Get current pathname
const currentPath = Astro.url.pathname;

// Helper function to check if a route is active
function isActive(route?: string): boolean {
  if (!route) return false;
  if (route === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(route);
}
---

<header class="inset-x-0 top-0 z-50">
  <script>
    function toggleSidebar() {
      [...document.getElementsByClassName("toggleable")].forEach((el) =>
        el.classList.toggle("hidden"),
      );
    }
    [...document.querySelectorAll("[data-toggle-sidebar]")].forEach((el) =>
      el.addEventListener("click", toggleSidebar),
    );
  </script>
  <nav
    class="flex items-center justify-between p-6 lg:px-8"
    aria-label="Global"
  >
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">508.dev</span>
        <img class="h-8 w-auto" src="/508logo.png" alt="508 logo" />
      </a>
    </div>
    <div class="flex lg:hidden">
      <button
        type="button"
        class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700"
        data-toggle-sidebar
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-12 items-center">
      {
        routes.map((route) => {
          const active = route.subItems
            ? route.subItems.some((item) => isActive(item.route))
            : isActive(route.route);

          if (route.subItems) {
            return (
              <div class="relative group">
                <button
                  type="button"
                  class={`flex items-center gap-x-1 text-sm font-semibold leading-6 text-gray-900 pb-1 ${
                    active ? "border-b-4 border-indigo-600" : ""
                  }`}
                  aria-haspopup="true"
                >
                  {route.name}
                  <svg
                    class="h-5 w-5 flex-none text-gray-400 group-hover:text-gray-500"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </button>
                <div class="absolute -left-8 top-full z-10 pt-2 hidden w-screen max-w-xs group-hover:block group-focus-within:block">
                  <div class="overflow-hidden rounded-3xl bg-white shadow-lg ring-1 ring-gray-900/5">
                    <div class="p-4">
                      {route.subItems.map((item) => (
                        <div class="group/item relative flex items-center gap-x-6 rounded-lg p-3 text-sm leading-6 hover:bg-gray-50">
                          <div class="flex-auto">
                            <a
                              href={item.route}
                              class={`block font-semibold text-gray-900 ${
                                isActive(item.route)
                                  ? "border-b-4 border-indigo-600"
                                  : ""
                              }`}
                            >
                              {item.name}
                              <span class="absolute inset-0" />
                            </a>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            );
          }

          return (
            <a
              href={route.route}
              class={`text-sm font-semibold leading-6 text-gray-900 relative pb-1 ${
                active ? "border-b-4 border-indigo-600" : ""
              }`}
            >
              {route.name}
            </a>
          );
        })
      }
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end"></div>
  </nav>
  <!-- Mobile menu, show/hide based on menu open state. -->
  <div class="lg:hidden hidden toggleable" role="dialog" aria-modal="true">
    <!-- Background backdrop, show/hide based on slide-over state. -->
    <div class="fixed inset-0 z-50"></div>
    <div
      class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white px-6 py-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10"
    >
      <div class="flex items-center justify-between">
        <a href="/" class="-m-1.5 p-1.5">
          <span class="sr-only">508.dev</span>
          <img class="h-8 w-auto" src="/508logo.png" alt="508 logo" />
        </a>
        <button
          type="button"
          class="-m-2.5 rounded-md p-2.5 text-gray-700"
          data-toggle-sidebar
        >
          <span class="sr-only">Close menu</span>
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/10">
          <div class="space-y-2 py-6">
            {
              routes.map((route) => {
                const active = route.subItems
                  ? route.subItems.some((item) => isActive(item.route))
                  : isActive(route.route);

                if (route.subItems) {
                  return (
                    <details class="-mx-3 group">
                      <summary
                        class={`flex w-full items-center justify-between rounded-lg py-2 pl-3 pr-3.5 text-base font-semibold leading-7 text-gray-900 hover:bg-gray-50 cursor-pointer list-none [&::-webkit-details-marker]:hidden ${
                          active ? "border-l-4 border-indigo-600 pl-2" : ""
                        }`}
                      >
                        {route.name}
                        <svg
                          class="h-5 w-5 flex-none transition-transform group-open:rotate-180"
                          viewBox="0 0 20 20"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                            clip-rule="evenodd"
                          />
                        </svg>
                      </summary>
                      <div class="mt-2 space-y-2">
                        {route.subItems.map((item) => (
                          <a
                            href={item.route}
                            class={`block rounded-lg py-2 pl-6 pr-3 text-sm font-semibold leading-7 text-gray-900 hover:bg-gray-50 ${
                              isActive(item.route)
                                ? "border-l-4 border-indigo-600 pl-2"
                                : ""
                            }`}
                          >
                            {item.name}
                          </a>
                        ))}
                      </div>
                    </details>
                  );
                }

                return (
                  <a
                    href={route.route}
                    class={`-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-gray-900 hover:bg-gray-50 relative ${
                      active ? "border-l-4 border-indigo-600 pl-2" : ""
                    }`}
                  >
                    {route.name}
                  </a>
                );
              })
            }
          </div>
          <div class="py-6"></div>
        </div>
      </div>
    </div>
  </div>
</header>
