---
export interface PortfolioType {
  id: string | number;
  small: string;
  header: string;
  content_p1?: string;
  content_p2?: string;
  content_p3?: string;
  content_p4?: string;
  img?: string;
  url?: string;
  testimonial?: {
    quote: string;
    author: string;
    role?: string;
  };
}
const {
  id,
  small,
  header,
  content_p1,
  content_p2,
  content_p3,
  content_p4,
  img,
  url,
  testimonial,
} = Astro.props.item;
---

<div class="bg-white py-24 sm:py-32" id={`portfolio-item-${id}`}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
      <p class="text-base font-semibold leading-7 text-indigo-600">{small}</p>
      <h1
        class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"
      >
        {header}
      </h1>
      {
        url && (
          <a
            href={url}
            class="mt-4 inline-flex text-sm font-semibold leading-6 text-cyan-700 hover:text-cyan-600"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit project <span aria-hidden="true">→</span>
          </a>
        )
      }
      {
        testimonial && (
          <figure class="mt-10 border-l-4 border-cyan-600 pl-6">
            <blockquote class="text-xl font-semibold leading-8 text-gray-900">
              <p>"{testimonial.quote}"</p>
            </blockquote>
            <figcaption class="mt-4 text-base leading-7 text-gray-600">
              <span class="font-semibold text-gray-900">
                {testimonial.author}
              </span>
              {testimonial.role && <span>, {testimonial.role}</span>}
            </figcaption>
          </figure>
        )
      }
      {
        (content_p1 || content_p2 || content_p3 || content_p4) && (
          <div class="mt-10 grid max-w-xl grid-cols-1 gap-8 text-base leading-7 text-gray-700 lg:max-w-none lg:grid-cols-2">
            <div>
              {content_p1 && <p>{content_p1}</p>}
              {content_p2 && <p class="mt-8">{content_p2}</p>}
            </div>
            <div>
              {content_p3 && <p>{content_p3}</p>}
              {content_p4 && <p class="mt-8">{content_p4}</p>}
            </div>
          </div>
        )
      }
    </div>
    {
      img && (
        <div class="relative overflow-hidden pt-16 lg:pt-20">
          <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <img
              class="mb-[-12%] rounded-xl shadow-2xl ring-1 ring-gray-900/10"
              src={img}
              alt=""
            />
            <div class="relative" aria-hidden="true">
              <div class="absolute -inset-x-20 bottom-0 bg-gradient-to-t from-white pt-[7%]" />
            </div>
          </div>
        </div>
      )
    }
  </div>
</div>
