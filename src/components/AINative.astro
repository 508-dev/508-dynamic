---
const { fields } = Astro.props;
const highlights = [1, 2, 3];
---

<section class="bg-slate-50 py-24 sm:py-32" id="ai-native">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div
      class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start"
    >
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-700"
        >
          {fields["ai_native_eyebrow"]?.content}
        </p>
        <h2
          class="mt-4 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          {fields["ai_native_title"]?.content}
        </h2>
      </div>
      <div>
        <p class="text-lg leading-8 text-slate-600">
          {fields["ai_native_description"]?.content}
        </p>
      </div>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        highlights.map((num) => (
          <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-lg font-semibold text-slate-900">
              {fields[`ai_native_${num}_title`]?.content}
            </h3>
            <p class="mt-3 text-base leading-7 text-slate-600">
              {fields[`ai_native_${num}_text`]?.content}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
